# Copy to .env.local and fill in. Never commit real secrets (.env* is git-ignored).

# --- Vercel Postgres ---
# Get these from your Vercel project → Storage → your Postgres DB → ".env.local" tab,
# or run: vercel env pull .env.local
POSTGRES_PRISMA_URL="postgres://user:password@host/db?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://user:password@host/db?sslmode=require"

# --- Auth.js ---
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-me"

# --- Owner (admin) account, used by `npm run db:seed`.
# OWNER_EMAIL also receives the "new booking request" notification email. ---
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="change-me-strong-password"
OWNER_NAME="Owner Name"

# --- Resend (booking request emails to guest + owner) ---
# Sign up at resend.com, verify your sending domain (adds a couple of DNS
# records), then create an API key. Without this set, booking requests still
# work — email sending is just skipped (logged as an error).
RESEND_API_KEY="re_your_api_key"
RESEND_FROM_EMAIL="noreply@domain.com"
