// Prisma schema for Il Cuore di Loco — booking system.
// Datasource uses the two connection strings Vercel Postgres provides:
//   POSTGRES_PRISMA_URL      → pooled connection (runtime queries)
//   POSTGRES_URL_NON_POOLING → direct connection (migrations)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Role {
  GUEST
  OWNER
}

enum BookingStatus {
  PENDING // guest submitted a request, awaiting owner decision
  CONFIRMED // owner accepted → blocks the dates
  CANCELLED // owner declined/cancelled
}

// Admin/owner accounts only — guests do not have accounts.
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(OWNER)
  createdAt    DateTime @default(now())
}

// A guest booking request (no account). Captures contact details inline.
model Booking {
  id        String        @id @default(cuid())
  guestName String
  email     String
  phone     String
  checkIn   DateTime      @db.Date // inclusive check-in
  checkOut  DateTime      @db.Date // exclusive check-out → half-open range [checkIn, checkOut)
  guests    Int           @default(2)
  message   String?
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())

  @@index([checkIn, checkOut])
}

// Newsletter subscribers captured from the homepage sign-up form.
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  createdAt DateTime @default(now())
}

// Owner-blocked dates (self-use, maintenance, …). Same half-open range semantics.
model BlockedRange {
  id        String   @id @default(cuid())
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())
}

// Singleton (id is always 1) holding the base pricing knobs. Self-initializes
// with defaults on first read — see lib/pricing.ts.
model PricingSettings {
  id                      Int      @id @default(1)
  baseNightlyPrice        Int // whole euros, e.g. 100
  weekendSurchargePercent Int // e.g. 10 — applies Fri & Sat nights
  cleaningFee             Int // whole euros, e.g. 50
  updatedAt               DateTime @updatedAt
}

// Owner-defined surcharge window (e.g. high season, holidays). Percentages
// stack multiplicatively with the weekend surcharge and with each other.
model SurchargePeriod {
  id        String   @id @default(cuid())
  startDate DateTime @db.Date // inclusive
  endDate   DateTime @db.Date // exclusive — half-open, same convention as BlockedRange
  percent   Int // e.g. 20 for +20%
  label     String?
  createdAt DateTime @default(now())
}

// Exact nightly price for one specific date — always wins over the computed price.
model PriceOverride {
  id    String   @id @default(cuid())
  date  DateTime @unique @db.Date
  price Int
}
